  "polymarket": {
    "gamma_api_url": "https://gamma-api.polymarket.com",
    "clob_api_url": "https://clob.polymarket.com",
    "private_key": "REPLACE_WITH_YOUR_64_CHAR_HEX_PRIVATE_KEY",
    "proxy_wallet_address": "0x0000000000000000000000000000000000000000",
